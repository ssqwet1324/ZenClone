{
    "swagger": "2.0",
    "info": {
        "description": "Сервис управления постами",
        "title": "Post Service API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8082",
    "basePath": "/api",
    "paths": {
        "/api/v1/posts/by-user/{userID}": {
            "get": {
                "description": "Возвращает список постов указанного пользователя с поддержкой cursor-based pagination.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Получение постов пользователя с пагинацией",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID пользователя",
                        "name": "userID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Количество постов за один запрос (по умолчанию 20, максимум 50)",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Cursor для следующей страницы, формат: created_at|post_id",
                        "name": "cursor",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список постов успешно получен",
                        "schema": {
                            "$ref": "#/definitions/entity.GetPostsUserSuccessResponse"
                        }
                    },
                    "400": {
                        "description": "Некорректный userID или limit",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Посты пользователя не найдены",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/posts/create": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Создает новый пост для текущего аутентифицированного пользователя",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Создание поста",
                "parameters": [
                    {
                        "description": "Данные для создания поста",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/entity.CreatePostRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Пост успешно создан",
                        "schema": {
                            "$ref": "#/definitions/entity.CreatePostSuccessResponse"
                        }
                    },
                    "400": {
                        "description": "Некорректное тело запроса или пустые поля",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Пользователь не авторизован",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/posts/delete/{postID}": {
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Удаляет пост, принадлежащий текущему пользователю",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Удаление поста",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID поста",
                        "name": "postID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Пост успешно удалён",
                        "schema": {
                            "$ref": "#/definitions/entity.DeletePostSuccessResponse"
                        }
                    },
                    "400": {
                        "description": "Некорректный postID",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Пользователь не авторизован",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Пост не принадлежит пользователю",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/posts/feed": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Возвращает список постов от пользователей, на которых подписан текущий пользователь, с поддержкой cursor-based pagination. Посты отсортированы по времени создания (от новых к старым).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Получение ленты постов подписок",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Username текущего пользователя",
                        "name": "username",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Количество постов за один запрос (по умолчанию 20, максимум 50)",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Cursor для следующей страницы, формат: created_at|post_id",
                        "name": "cursor",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Лента постов успешно получена",
                        "schema": {
                            "$ref": "#/definitions/entity.GetPostsUserSuccessResponseFromFeed"
                        }
                    },
                    "400": {
                        "description": "Некорректный username или limit",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Пользователь не авторизован",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Посты в ленте не найдены (нет подписок или постов)",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/posts/update/{postID}": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Обновляет существующий пост, принадлежащий текущему пользователю",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "posts"
                ],
                "summary": "Обновление поста",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID поста",
                        "name": "postID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Данные для обновления поста",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/entity.UpdateUserPostRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Пост успешно обновлён",
                        "schema": {
                            "$ref": "#/definitions/entity.UpdatePostSuccessResponse"
                        }
                    },
                    "400": {
                        "description": "Некорректный postID или пустые поля",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Пользователь не авторизован",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Пост не принадлежит пользователю",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/entity.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
